# ===============================
# API KEYS
# ===============================
GROQ_API_KEY=your_groq_api_key_here

# ===============================
# DOCUMENT PATH
# ===============================
# DOCUMENTS_PATH=...
# DOCUMENTS_PATH=./documents

# ===============================
# DIRECTORIES
# ===============================
CHROMA_DB_PATH=./chroma_db
METADATA_PATH=./chroma_db/.metadata.json

# ===============================
# FOUNDATION MODELS
# ===============================
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
LLM_MODEL=openai/gpt-oss-120b

# ===============================
# LLM CONFIGS
# ===============================
TEMPERATURE=0.3
MAX_TOKENS=2000

# ===============================
# TEXT SPLITTER
# ===============================
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
SEPARATORS=["\n\n", "\n", ". ", " ", ""]

# ===============================
# RETRIEVAL
# ===============================
SEARCH_TYPE=similarity
SEARCH_K=4
FETCH_K=20
LAMBDA_MULT=0.5
SCORE_THRESHOLD=0.5

# ===============================
# MEMORY
# ===============================
CONVERSATION_MEMORY_SIZE=5

# ===============================
# QUESTIONS
# ===============================
QUESTIONS=["What is RLHF?", "What is SFT?"]

# ===============================
# PREFERENCES
# ===============================
SHOW_SOURCES=True
SHOW_RETRIEVAL_DOCS=True
VERBOSE=True

# ===============================
# RE-INDEX
# ===============================
FORCE_REINDEX=False